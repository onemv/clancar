{
  "name": "@clancar/backend",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-backend.mjs dev",
    "build": "pnpm prisma:generate && tsc -p tsconfig.build.json",
    "start": "node scripts/run-backend.mjs start",
    "start:prod": "node scripts/run-backend.mjs start",
    "lint": "pnpm prisma:generate && tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm prisma:generate && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:export": "pnpm prisma:generate && tsx scripts/export-openapi.ts",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.835.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.1",
    "@prisma/client": "^6.12.0",
    "ioredis": "^5.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/node": "^24.3.0",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.12.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
